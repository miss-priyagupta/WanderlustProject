<% layout("/layouts/boilerplate") %>
<body>
    <%= success %>
    <style>
        #filters{
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            overflow-x: auto;
            white-space: nowrap;
            -ms-overflow-style: none;
            scrollbar-width: none;
            gap: 1rem;
        }
        #filters::-webkit-scrollbar{
            display: none;
        }

        @media(max-width:600px){
            .filter i{
                font-size: 1.2rem;
            }
            .filter p{
                font-size: 0.8rem;
            }
        }

        .filter{
            text-align: center;
            margin-right: 1rem;
            margin-top: 2rem;
            opacity: 0.6;
            flex: 0 0 auto
        }
        .filter:hover{
            opacity: 1;
            cursor: pointer;
        }
        .filter p{
            font-size: 0.8rem;
        }
        .tax-info{
            display: none;
        }
        .tax-toggle{
            border: 1px solid black;
            border-radius: 1rem;
            height: 3.2 5rem;
            padding: 1rem ;
            margin-left: 2rem;
            display: flex;
            align-items: center;
        }
        </style>
    <!-- <h3>All Listings</h3> -->
    <!-- <form method="GET" action="/listings/new">
        <button>Create New Listing</button>
    </form> -->

    <div id="filters">
        <div class="filter">
            <a href="/listings?category=rooms" class="filter" style="text-decoration: none; color: inherit;">
            <div><i class="fa-solid fa-fire"></i></div>
            <p>Rooms</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=trending" class="filter" style="text-decoration: none; color: inherit;">
            <div><i class="fa-solid fa-bed"></i></div>
            <p>Trending</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=iconic-cities" class="filter" style="text-decoration: none; color: inherit;">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Iconic Cities</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=mountains" class="filter" style="text-decoration: none; color: inherit;">
            <div><i class="fa-solid fa-mountain"></i></div>
            <p>Mointains</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=castles" class="filter" style="text-decoration: none; color: inherit;">
            <div><i class="fa-brands fa-fort-awesome"></i></div>
            <p>Castles</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=pools" class="filter" style="text-decoration: none; color: inherit;">
            <div><i class="fa-solid fa-person-swimming"></i></div>
            <p>Amazing Pools</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=camps" class="filter" style="text-decoration: none; color: inherit;">
            <div><i class="fa-solid fa-campground"></i></div>
            <p>Camping</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=farms" class="filter" style="text-decoration: none; color: inherit;">
            <div><i class="fa-solid fa-cow"></i></div>
            <p>Farming</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=arctic" class="filter" style="text-decoration: none; color: inherit;">
            <div><i class="fa-solid fa-snowflake"></i></div>
            <p>Arctic</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=dome" class="filter" style="text-decoration: none; color: inherit;">
            <div><i class="fa-solid fa-igloo"></i></div>
            <p>Dome</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=boat" class="filter" style="text-decoration: none; color: inherit;">
            <div><i class="fa-solid fa-sailboat"></i></i></div>
            <p>Boats</p>
            </a>
        </div>
        <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Display after total Taxes</label>
            </div>
        </div>
    </div>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
        <% if(allListings.length > 0){ %>
    <% for(let listing of allListings){ %>
        <a href="/listings/<%= listing._id %>">
    <div class="card col listing-card">
  <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem;">
  <div class="card-img-overlay"></div>
  <div class="card-body">
    <p class="card-text">
        <b><%= listing.title %></b> <br>
        &#8377; <%= listing.price.toLocaleString('en-IN') %> /night
        <i class="tax-info"> &nbsp; &nbsp; +18% GST</i>
    </p>
  </div>
</div>
</a>
<% } %>
<% } else { %>
    <div class="col-12 text-center mt-5">
        <h3>No Listings found</h3>
        <p>Try exploring another or <a href="/listings">View All</a>.</p>
    </div>
    <% } %>
    </div>

    <script>
        let taxSwitch = document.getElementById("switchCheckDefault");
        taxSwitch.addEventListener("click", () =>{
            let taxInfo = document.getElementsByClassName("tax-info");
            for(info of taxInfo){
                if(info.style.display != "inline"){
                    info.style.display = "inline";
                } else {
                    info.style.display = "none";
                }
                
            }
        });
    </script>